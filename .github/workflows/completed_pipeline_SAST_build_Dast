name: First_Secure DevSecOps SAST, Build, and DAST Pipeline

on:
  workflow_dispatch:

jobs:
  # 🧬 STAGE 1: Fast Code Linting
  semgrep-analysis:
    runs-on: ubuntu-latest
    container:
      image: semgrep/semgrep
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
      - name: Run Semgrep
        run: semgrep scan --config=p/security-audit --config=p/python --config=p/owasp-top-ten --include="app.py" --error

  # 🔬 STAGE 2: Deep Data-Flow Analysis
  codeql-analysis:
    runs-on: ubuntu-latest
    permissions:
      security-events: write
      actions: read
      contents: read
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4
      - name: Initialize CodeQL
        uses: github/codeql-action/init@v3
        with:
          languages: 'python'
      - name: Perform CodeQL Analysis
        uses: github/codeql-action/analyze@v3
        with:
          category: "/language:python"

  # 🐳 STAGE 3: Build & Scan Container Artifacts
  container-build:
    runs-on: ubuntu-latest
    needs: [semgrep-analysis, codeql-analysis] # Waits for both SAST scanners to pass
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Building Docker Image
        run: docker build -t app-image:v1 .

      - name: Run Trivy Scan
        uses: aquasecurity/trivy-action@v0.35.0
        with:
          image-ref: 'app-image:v1'
          scan-type: 'image'
          format: 'table'
          exit-code: '0'

  # ⚡ STAGE 4: Live Runtime DAST Attack Phase
  dynamic-application-testing:
    runs-on: ubuntu-latest
    needs: container-build # 👈 Only runs if the Docker image builds successfully
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      # DAST requires the app to be running. We build and run it directly on the runner machine.
      - name: Boot Up Application in Background
        run: |
          docker build -t dast-target:latest .
          # Run the container locally mapped to port 5000 in background mode (-d)
          docker run -d -p 5000:5000 --name running-app dast-target:latest
          
          # Give the Flask server 5 seconds to fully initialize and wake up
          sleep 5
          
          # Verify the local runner machine can successfully talk to the running web application
          curl -I http://localhost:5000/profile

      # Launches the official OWASP ZAP Baseline scanner tool to attack localhost:5000
      - name: Execute OWASP ZAP DAST Scan
        uses: zaproxy/action-baseline@v0.14.0
        with:
          target: 'http://localhost:5000'
          token: ${{ secrets.GITHUB_TOKEN }}
          # 'true' ensures the pipeline stays green for your logs review even when vulnerabilities are found
          fail_action: false 
